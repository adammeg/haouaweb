# Required for doctor sessions (JWT). Use a long random string (32+ chars).
AUTH_SECRET=change-me-to-a-long-random-secret-key

# MongoDB (local example). Database name can also be set via MONGODB_DB_NAME.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=hawae_md

# Optional — IA (/api/ia). Priorité : OpenRouter, sinon OpenAI direct.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=http://localhost:3000
# OPENROUTER_APP_TITLE=HawaeMD
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# IA_MAX_TOKENS=2048
# IA_TEMPERATURE=0.3

# Optional — CORS for mobile / Expo Web (comma-separated origins, or *)
# MOBILE_CORS_ORIGIN=http://localhost:8081,exp://192.168.1.10:8081
